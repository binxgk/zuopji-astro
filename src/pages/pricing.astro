---
// pricing.astro → 价格示意页
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

// ========== 场照报价 ==========
const changzhao = [
  { name: '四图场照', price: '80', items: ['拍摄 + 调色简修', '数量 4 图', '拍摄时长约 30min'] },
  { name: '六图场照', price: '120', items: ['拍摄 + 调色简修', '数量 6 图', '拍摄时长约 30min'] },
  { name: '九图场照', price: '180', items: ['拍摄 + 调色简修', '数量 9 图', '拍摄时长约 30min'] },
];

// ========== 正片报价 ==========
const zhengpian = [
  {
    name: '单人正片',
    price: '299',
    subtitle: '棚拍',
    items: [
      '9 图，底图保底 100+',
      '前期策划执行案',
      '修容 + 调色 + 小 bug 处理',
    ],
  },
  {
    name: '单人正片',
    price: '399',
    subtitle: '外景',
    items: [
      '9 图，底图保底 100+',
      '前期策划执行案',
      '修容 + 调色 + 小 bug 处理',
    ],
  },
  {
    name: '双人正片',
    price: '399',
    subtitle: '棚拍',
    items: [
      '9 图，底图保底 200+',
      '前期策划执行案',
      '修容 + 调色 + 小 bug 处理',
    ],
  },
  {
    name: '双人正片',
    price: '599',
    subtitle: '外景',
    items: [
      '9 图，底图保底 200+',
      '前期策划执行案',
      '修容 + 调色 + 小 bug 处理',
    ],
  },
];

// ========== 增值服务 ==========
const changzhaoAddons = [
  { label: '精修半合成', price: '20', unit: '元/张' },
  { label: '双人场照', price: '单人价格×2', unit: '' },
];
const zhengpianAddons = [
  { label: '2D 特效合成', price: '30', unit: '起/张' },
  { label: '3D 特效合成', price: '需沟通', unit: '' },
];

// ========== 场照注意事项 ==========
const changzhaoNotes = [
  { title: '流程', desc: '定金定档 → 拍摄 → 尾款 → 返图' },
  { title: '返图周期', desc: '漫展结束晚上返底图，选图后 7~14 天内返简/精修图' },
  { title: '定金', desc: '定金 50%，跑单定金不退' },
  { title: '拍摄时长', desc: '漫展当天会给具体灯阵位置，拍摄时长约 30min 左右' },
  { title: '返图格式', desc: '返图默认 JPG，如有需要 RAW 可提出' },
  { title: '动作准备', desc: '需提前准备动作，只提供动作指导和修正' },
  { title: '成片授权', desc: '成片默认可发社交平台，如不同意需提前说明' },
];

// ========== 正片注意事项 ==========
const zhengpianNotes = [
  { title: '定金', desc: '正片定金 150 元' },
  { title: '出图工期', desc: '正片出图工期 7~14 天，如有特效合成可能会因工作量需延迟' },
  { title: '迟到说明', desc: '单主迟到一小时默认取消拍摄（提前说明可延迟最多一小时）' },
  { title: '路费说明', desc: '有地铁直达无需单主报销，目的地离地铁超过 2 公里需单主报销' },
];
---

<BaseLayout title="拍摄报价参考 — 氷子" description="摄影约拍价格套餐与增值服务" currentPage="pricing">

  <!-- Hero -->
  <section class="pricing-hero">
    <p class="pricing-eyebrow">PHOTO</p>
    <h1>拍摄报价参考</h1>
    <p class="pricing-subtitle">以下为场照与正片的参考报价，具体可根据需求协商调整。</p>
  </section>

  <!-- ===== 场照报价 ===== -->
  <section class="pricing-section">
    <h2 class="pricing-section-title">场照</h2>
    <div class="pricing-grid pricing-grid--3col">
      {changzhao.map((pkg, i) => (
        <div class="pricing-card" style={`animation-delay: ${i * 100}ms`}>
          <h3 class="pricing-card-name">{pkg.name}</h3>
          <div class="pricing-card-price">
            <span class="pricing-amount">{pkg.price}</span>
            <span class="pricing-unit">元</span>
          </div>
          <ul class="pricing-items">
            {pkg.items.map(item => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== 场照增值服务 ===== -->
  <section class="pricing-addons">
    <h2 class="pricing-section-title">场照增值服务</h2>
    <div class="addons-grid">
      {changzhaoAddons.map((item, i) => (
        <div class="addon-item" style={`animation-delay: ${(i + 3) * 80}ms`}>
          <span class="addon-label">{item.label}</span>
          <span class="addon-price">
            {item.price}
            {item.unit && <em>{item.unit}</em>}
          </span>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== 场照注意事项 ===== -->
  <section class="pricing-notes">
    <h2 class="pricing-section-title">场照注意事项</h2>
    <div class="notes-list">
      {changzhaoNotes.map((note, i) => (
        <div class="note-item" style={`animation-delay: ${(i + 5) * 60}ms`}>
          <span class="note-num">{i + 1}</span>
          <div class="note-content">
            <span class="note-title">{note.title}</span>
            <span class="note-desc">{note.desc}</span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== 正片报价 ===== -->
  <section class="pricing-section">
    <h2 class="pricing-section-title">正片</h2>
    <div class="pricing-grid pricing-grid--2col">
      {zhengpian.map((pkg, i) => (
        <div class="pricing-card pricing-card--zhengpian" style={`animation-delay: ${(i + 8) * 100}ms`}>
          <div class="zhengpian-header">
            <h3 class="pricing-card-name">{pkg.name}</h3>
            <span class="zhengpian-subtitle">{pkg.subtitle}</span>
          </div>
          <div class="pricing-card-price">
            <span class="pricing-amount">{pkg.price}</span>
            <span class="pricing-unit">元</span>
          </div>
          <ul class="pricing-items">
            {pkg.items.map(item => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== 正片增值服务 ===== -->
  <section class="pricing-addons">
    <h2 class="pricing-section-title">正片增值服务</h2>
    <div class="addons-grid">
      {zhengpianAddons.map((item, i) => (
        <div class="addon-item" style={`animation-delay: ${(i + 12) * 80}ms`}>
          <span class="addon-label">{item.label}</span>
          <span class="addon-price">
            {item.price}
            {item.unit && <em>{item.unit}</em>}
          </span>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== 正片注意事项 ===== -->
  <section class="pricing-notes">
    <h2 class="pricing-section-title">正片注意事项</h2>
    <div class="notes-list">
      {zhengpianNotes.map((note, i) => (
        <div class="note-item" style={`animation-delay: ${(i + 14) * 60}ms`}>
          <span class="note-num">{i + 1}</span>
          <div class="note-content">
            <span class="note-title">{note.title}</span>
            <span class="note-desc">{note.desc}</span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== 查看更多 ===== -->
  <section class="pricing-social">
    <p>如需要查看更多例图</p>
    <p>可以查看同名 <strong>小红书</strong>、<strong>抖音</strong> ~</p>
  </section>

  <!-- CTA Bottom -->
  <section class="pricing-bottom-cta">
    <h2>联系方式</h2>
    <div class="pricing-contact">
      <span>QQ：2166783550</span>
      <span class="pricing-contact-sep">·</span>
      <span>VX：anzzbfly</span>
    </div>
  </section>

  <style>
  /* ---- Pricing Page ---- */

  .pricing-hero {
    text-align: center;
    padding: 3rem 0 1.5rem;
    opacity: 0;
    animation: pricingFadeUp 0.8s ease forwards;
  }
  .pricing-eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    color: var(--accent-dark);
    margin-bottom: 0.6rem;
    text-transform: uppercase;
  }
  .pricing-hero h1 {
    font-size: clamp(2rem, 7vw, 3.2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }
  .pricing-subtitle {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* ---- Section ---- */
  .pricing-section {
    margin-bottom: 2.5rem;
    opacity: 0;
    animation: pricingFadeUp 0.7s 0.15s ease forwards;
  }
  .pricing-section-title {
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    margin-bottom: 1rem;
    padding-left: 0.2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .pricing-section-title::before {
    content: '';
    display: inline-block;
    width: 3px;
    height: 1em;
    background: var(--accent);
    border-radius: 2px;
  }

  /* ---- Grid ---- */
  .pricing-grid {
    display: grid;
    gap: 1rem;
  }
  .pricing-grid--3col {
    grid-template-columns: repeat(3, 1fr);
  }
  .pricing-grid--2col {
    grid-template-columns: repeat(2, 1fr);
  }
  @media (max-width: 768px) {
    .pricing-grid--3col,
    .pricing-grid--2col {
      grid-template-columns: 1fr;
    }
  }

  /* ---- Card ---- */
  .pricing-card {
    background: var(--bg-card);
    border-radius: var(--radius);
    padding: 1.6rem 1.4rem;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-card);
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.3s ease;
    opacity: 0;
    animation: pricingFadeUp 0.6s ease forwards;
  }
  .pricing-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-hover);
  }

  .pricing-card-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.8rem;
  }

  .pricing-card-price {
    display: flex;
    align-items: baseline;
    gap: 4px;
    margin-bottom: 1.2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }
  .pricing-amount {
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--text-primary);
  }
  .pricing-unit {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--accent-dark);
  }

  /* ---- Zhengpian Card ---- */
  .pricing-card--zhengpian .zhengpian-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.8rem;
  }
  .zhengpian-subtitle {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent-dark);
    background: rgba(127, 239, 208, 0.15);
    padding: 3px 10px;
    border-radius: 12px;
  }

  /* ---- Items List ---- */
  .pricing-items {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .pricing-items li {
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.5;
    padding-left: 0.8rem;
    position: relative;
  }
  .pricing-items li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent);
  }

  /* ---- Add-ons ---- */
  .pricing-addons {
    margin-bottom: 2.5rem;
    opacity: 0;
    animation: pricingFadeUp 0.7s 0.3s ease forwards;
  }
  .addons-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.8rem;
    max-width: 400px;
  }
  .addon-item {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 1.1rem 0.8rem;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    opacity: 0;
    animation: pricingFadeUp 0.5s ease forwards;
  }
  .addon-item:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-card);
  }
  .addon-label {
    display: block;
    font-size: 0.78rem;
    color: var(--text-secondary);
    margin-bottom: 0.3rem;
  }
  .addon-price {
    display: block;
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }
  .addon-price em {
    font-style: normal;
    font-size: 0.68rem;
    font-weight: 400;
    color: var(--text-muted);
  }

  /* ---- Notes ---- */
  .pricing-notes {
    margin-bottom: 2.5rem;
    opacity: 0;
    animation: pricingFadeUp 0.7s 0.4s ease forwards;
  }
  .notes-list {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.4rem 1.6rem;
  }
  .note-item {
    display: flex;
    align-items: flex-start;
    gap: 0.8rem;
    opacity: 0;
    animation: pricingFadeUp 0.4s ease forwards;
  }
  .note-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--accent);
    color: #1a1a24;
    font-size: 0.7rem;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .note-content {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .note-title {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-primary);
  }
  .note-desc {
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  /* ---- Social ---- */
  .pricing-social {
    text-align: center;
    padding: 2rem 1.5rem;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: pricingFadeUp 0.7s 0.6s ease forwards;
  }
  .pricing-social p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 0.2rem;
  }
  .pricing-social strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  /* ---- Bottom CTA ---- */
  .pricing-bottom-cta {
    text-align: center;
    padding: 2.5rem 1.5rem;
    background: var(--bg-card);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    opacity: 0;
    animation: pricingFadeUp 0.7s 0.7s ease forwards;
  }
  .pricing-bottom-cta h2 {
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 0.8rem;
  }
  .pricing-contact {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    font-size: 0.85rem;
    color: var(--text-primary);
    font-weight: 500;
  }
  .pricing-contact-sep {
    color: var(--text-muted);
  }

  /* ---- Animation ---- */
  @keyframes pricingFadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  </style>

</BaseLayout>
